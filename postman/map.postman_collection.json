      "name": "API v1",
      "item": [
        {
          "name": "Search places (Goong) - query only",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/map/places/goong?query=VNG&limit=12&local_only=false",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "map", "places", "goong"],
              "query": [
                { "key": "query", "value": "VNG" },
                { "key": "limit", "value": "12" },
                { "key": "local_only", "value": "false" }
              ]
            },
            "description": "Ưu tiên DB core.places, không có thì gọi Goong và lưu DB."
          }
        },
        {
          "name": "Search places (Goong) - local only",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/map/places/goong?query=pho&limit=12&local_only=true",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "map", "places", "goong"],
              "query": [
                { "key": "query", "value": "pho" },
                { "key": "limit", "value": "12" },
                { "key": "local_only", "value": "true" }
