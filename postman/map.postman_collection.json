                { "key": "limit", "value": "12" },
                { "key": "local_only", "value": "false" }
              ]
            }
          }
        },
        {
          "name": "Nearby places (no query, coords only)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/map/places/goong?near_lat=10.7769&near_lng=106.7009&limit=12&local_only=false",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "map", "places", "goong"],
              "query": [
                { "key": "near_lat", "value": "10.7769" },
                { "key": "near_lng", "value": "106.7009" },
                { "key": "limit", "value": "12" },
                { "key": "local_only", "value": "false" }
              ]
            },
            "description": "Không cần query khi có near_lat + near_lng."
          }
        },
        {
          "name": "Search places (vietmap alias)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/map/places/vietmap?query=VNG&limit=12",
