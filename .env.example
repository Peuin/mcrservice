# Peuin mcrservice — copy to .env (local) or inject via K8s Secret (production).
# Never commit .env with real secrets.

NODE_ENV=development
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=info

# ── Supabase (self-hosted Peuin Journal) ─────────────────────────────────────
# Root URL — REST API: {SUPABASE_URL}/rest/v1/
SUPABASE_URL=https://api.peuinjournal.com
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ── CORS ─────────────────────────────────────────────────────────────────────
# Production: comma-separated allowed origins (no * with credentials)
# Local dev: * or http://localhost:3000
CORS_ORIGIN=*

# ── Security response headers (optional — nginx/gateway may set these) ───────
SECURITY_HSTS_MAX_AGE=31536000
SECURITY_ENABLE_CSP=true

# ── OTP / Auth (optional) ───────────────────────────────────────────────────
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_HASH_SECRET=change-me
PASSWORD_MIN_LENGTH=8

# ── External APIs (server-only secrets) ─────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GOONG_PLACE_API_KEY=
GOONG_MAP_API_KEY=

# ── Storage / CDN ───────────────────────────────────────────────────────────
BUNNY_STORAGE_ZONE=
BUNNY_STORAGE_API_KEY=
BUNNY_STORAGE_HOST=storage.bunnycdn.com
BUNNY_STORY_CDN_BASE_URL=

# ── Worker warm jobs ────────────────────────────────────────────────────────
HOME_FEED_WARM_SECRET=
APP_SEARCH_WARM_SECRET=
NOTIFICATION_PUSH_SECRET=
HOME_FEED_WARM_VIEWER_LIMIT=200
RESEND_FEEDBACK_TO_EMAIL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
FCM_SERVICE_ACCOUNT_JSON=
FCM_PROJECT_ID=
VIETMAP_API_KEY=
VIETMAP_PLACE_API_KEY=
PERSONALITY_MARKDOWN_URL=
PERSONALITY_MARKDOWN_BEARER_TOKEN=
