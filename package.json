{
  "name": "mcrservice",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "NODE_ENV=development tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "check:supabase-config": "node scripts/check-supabase-config.mjs",
    "start": "node dist/server.js",
    "start:prod": "NODE_ENV=production node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "10.1.0",
    "@fastify/swagger": "9.5.1",
    "@fastify/swagger-ui": "5.2.6",
    "@supabase/supabase-js": "2.50.0",
    "dotenv": "16.5.0",
    "fastify": "5.8.5",
    "zod": "3.25.56"
  },
  "devDependencies": {
    "@types/node": "22.15.29",
    "tsx": "4.19.4",
    "typescript": "5.8.3"
  }
}
